 use serde::Deserialize;
 use std::process::Command;

+
+// ── Null-safe deserializers (Vertex AI returns null for cost/token fields) ──
+
+fn null_to_zero_u64<'de, D>(de: D) -> Result<u64, D::Error>
+where
+    D: serde::Deserializer<'de>,
+{
+    Ok(Option::<u64>::deserialize(de)?.unwrap_or(0))
+}
+
+fn null_to_zero_f64<'de, D>(de: D) -> Result<f64, D::Error>
+where
+    D: serde::Deserializer<'de>,
+{
+    Ok(Option::<f64>::deserialize(de)?.unwrap_or(0.0))
+}
+
