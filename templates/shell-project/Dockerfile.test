FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && apt-get install -y \
    bash \
    shellcheck \
    jq \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install just
RUN curl -fsSL https://just.systems/install.sh | bash -s -- --to /usr/local/bin

WORKDIR /repo
COPY . .

RUN bash script/install-bats.sh

CMD ["just", "check"]
